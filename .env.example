# Copy to .env and fill in real values. NEVER commit .env.
DJANGO_SECRET_KEY=change-me-in-prod-use-a-very-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Postgres
POSTGRES_DB=fanpitch
POSTGRES_USER=fanpitch
POSTGRES_PASSWORD=fanpitch
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis (channel layer + cache + celery broker)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=fanpitch-media-dev
CLOUDFRONT_DOMAIN=

# Bedrock (set to true ONLY if you have access + want to pay per token)
BEDROCK_ENABLED=false
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Football-Data.org API key (get one free at https://www.football-data.org/)
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# Simulator
SIMULATOR_DEFAULT_SPEED=10
