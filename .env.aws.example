# ─────────────────────────────────────────────────────────────────────
# FanPitch — Production env for AWS Innovation Sandbox (eu-central-1)
# Copy this to `.env` on the EC2 instance and fill in the placeholders.
# ─────────────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=__REPLACE_WITH_python_-c_'import_secrets;print(secrets.token_urlsafe(64))'__
DJANGO_DEBUG=False
# Add the EC2 public DNS once you have it (e.g. ec2-3-126-xxx-xxx.eu-central-1.compute.amazonaws.com)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,__EC2_PUBLIC_DNS__,__EC2_PUBLIC_IP__

# Postgres on RDS (eu-central-1)
POSTGRES_DB=fanpitch
POSTGRES_USER=fanpitch
POSTGRES_PASSWORD=__RDS_MASTER_PASSWORD__
POSTGRES_HOST=__RDS_ENDPOINT__.eu-central-1.rds.amazonaws.com
POSTGRES_PORT=5432

# Redis (running inside the same docker-compose stack on the EC2 host)
REDIS_URL=redis://redis:6379/0

# CORS — add the Flutter web origin if you also publish a web build, plus the
# EC2 public DNS so the Flutter app can hit /api/v1 over HTTP.
CORS_ALLOWED_ORIGINS=http://__EC2_PUBLIC_DNS__:8000,http://__EC2_PUBLIC_DNS__,http://localhost:3000

# AWS — use the IAM Instance Profile (NO access keys in .env on the EC2)
AWS_REGION=eu-central-1
# Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY EMPTY:
# boto3 will pick up the instance-profile credentials automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket for user media (presigned uploads). Created by setup_aws_sandbox.sh.
S3_BUCKET=fanpitch-media-__ACCOUNT_ID__
CLOUDFRONT_DOMAIN=

# Bedrock — Claude 3 Haiku in eu-central-1 (request model access in the console first)
BEDROCK_ENABLED=true
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Football-Data — leave blank to use the offline simulator (recommended for the demo)
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# Simulator
SIMULATOR_DEFAULT_SPEED=10
